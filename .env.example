# --- Required ---
BITBUCKET_URL=https://bitbucket.company.com
BITBUCKET_TOKEN=
BITBUCKET_WEBHOOK_SECRET=
BITBUCKET_USERNAME=
# Long-lived GitHub OAuth token (provision via hack/copilot-provision-token.sh)
COPILOT_OAUTH_TOKEN=
DATABASE_URL=postgresql://noergler:changeme@localhost:5432/noergler
JIRA_URL=https://jira.company.com
JIRA_TOKEN=

# --- Review behavior (values shown are current defaults) ---
# REVIEW_AUTO_REVIEW_AUTHORS=           # comma-separated; empty = review all authors
# REVIEW_MAX_COMMENTS=25
# REVIEW_MAX_FILE_LINES=1000               # files exceeding this line count are reviewed without full file context
# REVIEW_DIFF_EXTRA_LINES_BEFORE=3      # context lines added before each diff hunk
# REVIEW_DIFF_EXTRA_LINES_AFTER=2       # context lines added after each diff hunk
# REVIEW_DIFF_MAX_EXTRA_LINES_DYNAMIC_CONTEXT=10  # how far above the context window to search for enclosing function/class definition
# REVIEW_DIFF_ALLOW_DYNAMIC_CONTEXT=true          # extend diff context to include enclosing function/class definition
# REVIEW_PROMPT_TEMPLATE=prompts/review.txt
# REVIEW_MENTION_PROMPT_TEMPLATE=prompts/mention.txt
# REVIEW_TICKET_COMPLIANCE_CHECK=true   # evaluate PR against Jira ticket acceptance criteria

# --- Jira (values shown are current defaults) ---
# JIRA_ACCEPTANCE_CRITERIA_PREFIXES=AC,AK,Acceptance Criteria,Acceptance Criterion,Akzeptanzkriterium,Akzeptanzkriterien,DoD,Req

# --- AI model (values shown are current defaults) ---
# COPILOT_MODEL=gpt-5.3-codex
# COPILOT_API_URL=https://api.business.githubcopilot.com   # overridden by endpoints.api from token exchange
# COPILOT_INTEGRATION_ID=vscode-chat
# COPILOT_EDITOR_VERSION=vscode/1.99.0

# --- Server (values shown are current defaults) ---
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080
